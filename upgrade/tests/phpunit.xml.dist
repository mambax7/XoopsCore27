<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/11.2/phpunit.xsd"
         bootstrap="bootstrap.php"
         colors="true"
         cacheDirectory=".phpunit.cache"
         failOnWarning="true"
         failOnNotice="true">
    <testsuites>
        <testsuite name="smarty5-readiness">
            <directory>Smarty5</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory suffix=".php">../class/Xoops/Upgrade</directory>
        </include>
    </source>
</phpunit>
